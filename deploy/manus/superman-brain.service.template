[Unit]
Description=Goldfront OS Brain + Conrad Command Center
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__BRAIN_DIR__
Environment=GOLDFRONT_OWNER=__GOLDFRONT_OWNER__
ExecStart=__BRAIN_DIR__/.venv/bin/uvicorn brain.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
