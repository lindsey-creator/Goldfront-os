# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=
GOLDFRONT_OWNER=lindsey

# ClickUp API v2 — https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=90141259054
CLICKUP_AUTO_SYNC=true

# Fieldy — user-provided token; copy from Mac goldfront-os/.env to Manus .env
FIELDY_API_TOKEN=
FIELDY_API_BASE=https://api.fieldy.ai
FIELDY_SPEAKER_ME=Lindsey

# Google OAuth (Calendar + Gmail) — one refresh token with both scopes
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# GoHighLevel — Settings → API Keys
GHL_API_KEY=
GHL_LOCATION_ID=FFdZCVGXSQQThtHZEOYx

# Whoop OAuth — https://developer.whoop.com (see deploy/WHOOP-SETUP.md)
# Persistent: client id + secret + refresh token (python3 scripts/whoop_oauth_setup.py)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=
# Legacy static token — expires ~1h; prefer OAuth trio above
WHOOP_ACCESS_TOKEN=

# Apple Health — path to a JSON export your sync writes (display only)
APPLE_HEALTH_EXPORT_PATH=

# Legacy MCP (optional)
CLICKUP_MCP_URL=https://mcp.clickup.com/mcp
DECISION_HALFLIFE_DAYS=180
